{
  "name": "wellbore-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:vite --external:better-sqlite3 --sourcemap --outfile=dist/server.cjs",
    "build:wasm": "wasm-pack build rust/wellbore-wasm --target web --out-dir ../../src/wasm --out-name wellbore_wasm",
    "build:all": "npm run build:wasm && npm run build",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "dist:exe": "node build-dist.cjs"
  },
  "build": {
    "appId": "com.wellbore.pro",
    "productName": "Wellbore Schematic Pro",
    "copyright": "Copyright © oh.a.halim",
    "directories": {
      "output": "build-desktop"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "wellborePro.ico",
      ".env.local",
      ".env"
    ],
    "win": {
      "icon": "wellborePro.ico",
      "executableName": "WellboreSchematicPro",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wellbore Schematic Pro",
      "installerIcon": "wellborePro.ico",
      "uninstallerIcon": "wellborePro.ico",
      "uninstallDisplayName": "Wellbore Schematic Pro",
      "artifactName": "WellboreSchematicPro Setup.${ext}"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.4.0",
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/quill": "^2.0.14",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "quill": "^2.0.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "three": "^0.185.1",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.4",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.4",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
